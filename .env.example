# Apex Timing
APEX_WS_HOST=www.apex-timing.com
APEX_WS_PORT=8092
APEX_PHP_API_URL=https://www.apex-timing.com/live-timing/karting-los-santos/api.php

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/boxboxnow.db

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Auth (CHANGE IN PRODUCTION!)
JWT_SECRET=change-me-to-a-random-string-in-production
JWT_EXPIRE_MINUTES=1440

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/race
FRONTEND_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_BASIC_MONTHLY_PRICE_ID=price_...
STRIPE_BASIC_ANNUAL_PRICE_ID=price_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_EVENT_PRICE_ID=price_...

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend)
RESEND_API_KEY=re_...
FROM_EMAIL=BoxBoxNow <noreply@boxboxnow.com>
