<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>es</string>
	<key>CFBundleDisplayName</key>
	<string>BoxBoxNow</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.kartingnow.boxboxnow</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>boxboxnow</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<key>NSFaceIDUsageDescription</key>
	<string>BoxBoxNow usa Face ID para que puedas iniciar sesion de forma rapida y segura.</string>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>BoxBoxNow necesita Bluetooth para conectar con tu RaceBox GPS y recibir datos de telemetria en tiempo real durante la carrera.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>BoxBoxNow necesita acceso al GPS para detectar cruces de linea de meta, calcular velocidad y medir fuerzas G durante la carrera.</string>
	<key>NSMotionUsageDescription</key>
	<string>BoxBoxNow necesita acceso al acelerometro para medir las fuerzas G laterales y longitudinales durante la conduccion.</string>
	<key>UILaunchScreen</key>
	<dict>
		<key>BackgroundColor</key>
		<string>systemBlackColor</string>
		<key>ImageName</key>
		<string>LaunchIcon</string>
		<key>ImageRespectsSafeAreaInsets</key>
		<true/>
	</dict>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIUserInterfaceStyle</key>
	<string>Dark</string>
</dict>
</plist>
