<?xml version="1.0" encoding="utf-8"?>
<!--
    BBN logo for the splash screen — matches the in-app LoginScreen
    header rendered with InterFontFamily Black ("BB" white, "N" green).
    Two white "B"s with a real left spine + two right lobes each (with
    a slight horizontal indent at the waist to read as a letter rather
    than a rounded blob), and a green "N" with two verticals + a
    diagonal stroke. The previous version drew each B as just two
    stacked half-D shapes (no spine), which read as commas.

    Sized for the Android 12+ Splash Screen API: 240dp viewport with
    only the inner ~160dp circle guaranteed visible. The BBN block
    spans x=66..174 and y=85..155, comfortably inside that safe area.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="240dp"
    android:height="240dp"
    android:viewportWidth="240"
    android:viewportHeight="240">

    <!-- B 1 (white): vertical spine + top lobe + bottom lobe -->
    <!-- Spine: x=66..78 (12 wide) — Lobes peak at x≈100 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M66,85 h12 v70 h-12 z M78,85 h6 a17,16 0 0,1 0,32 h-6 z M78,123 h6 a17,16 0 0,1 0,32 h-6 z" />

    <!-- B 2 (white): same shape, shifted +36 (gap of 6 from B1's right) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M102,85 h12 v70 h-12 z M114,85 h6 a17,16 0 0,1 0,32 h-6 z M114,123 h6 a17,16 0 0,1 0,32 h-6 z" />

    <!-- N (accent green): left vertical + right vertical + diagonal -->
    <!-- Verticals: x=140..152 and x=162..174 — Diagonal connects them -->
    <path
        android:fillColor="#41D238"
        android:pathData="M140,85 h12 v70 h-12 z M162,85 h12 v70 h-12 z M152,85 h10 l10,70 h-10 z" />
</vector>
