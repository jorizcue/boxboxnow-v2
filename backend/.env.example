# Database
DATABASE_URL=sqlite+aiosqlite:///./data/boxboxnow.db

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
ALLOWED_ORIGINS=https://boxboxnow.com,https://www.boxboxnow.com

# Auth — REQUIRED: set a strong random secret (e.g. openssl rand -base64 48)
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_BASIC_MONTHLY_PRICE_ID=price_...
STRIPE_BASIC_ANNUAL_PRICE_ID=price_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_EVENT_PRICE_ID=price_...
FRONTEND_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Chatbot — RAG support agent on /dashboard
# OpenAI is used only for embeddings (text-embedding-3-small ~ $0.02/M tokens).
# Groq runs the LLM (Llama 3.1 8B Instant on free tier).
OPENAI_API_KEY=
GROQ_API_KEY=
# Optional caps. Defaults are conservative; tune to taste.
CHATBOT_DAILY_MESSAGE_LIMIT=30
CHATBOT_MAX_INPUT_CHARS=800
CHATBOT_MAX_OUTPUT_TOKENS=600
CHATBOT_LLM_MODEL=llama-3.1-8b-instant
CHATBOT_EMBED_MODEL=text-embedding-3-small
CHATBOT_TOP_K=5
